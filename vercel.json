{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "netzero-search.com" }],
      "destination": "https://www.netzero-search.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
